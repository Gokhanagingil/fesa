NODE_ENV=development
# Staging: use NODE_ENV=staging (validated) — see apps/api/.env.staging.example
API_PORT=3000
API_GLOBAL_PREFIX=api
# PostgreSQL connection string (required). Example for local Docker:
DATABASE_URL=postgresql://amateur:amateur@localhost:5432/amateur
# Schema: true = TypeORM may auto-sync (dev); false = rely on migrations only
# DB_SYNCHRONIZE=true
# Run pending migrations on API boot (staging/prod option)
# DB_RUN_MIGRATIONS=false
# Optional default tenant UUID for API calls without X-Tenant-Id (local only)
# After `npm run seed:demo`, the demo tenant id is:
# DEV_TENANT_ID=a0000001-0000-4000-8000-000000000001
# Comma-separated browser origins for CORS (optional in dev)
CORS_ORIGIN=http://localhost:5173
# Optional WhatsApp Cloud API access token (Wave 15 readiness pack).
# Tenants reference this token from the admin UI by saving the access
# token reference as `env:WHATSAPP_CLOUD_API_TOKEN`; the platform never
# stores the secret itself.  Until the live integration ships, leaving
# this unset keeps every tenant in assisted mode.
# WHATSAPP_CLOUD_API_TOKEN=
# Optional override for the local media storage root (Wave 16). Defaults to
# `<cwd>/storage/media`. Point this at a persistent volume in production so
# uploaded athlete photos survive across deploys.
# MEDIA_STORAGE_ROOT=/var/lib/amateur/media
