# Staging API environment (copy to apps/api/.env on the server — never commit .env)
#
# Create on the server once:
#   cp apps/api/.env.staging.example apps/api/.env
#   chmod 600 apps/api/.env
# Then set DATABASE_URL and any overrides.

NODE_ENV=staging
API_PORT=3000
API_GLOBAL_PREFIX=api

# Required — PostgreSQL connection string (staging database only)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Staging: do not auto-sync schema; migrations run in deploy script
DB_SYNCHRONIZE=false

# Optional: run migrations on API boot (deploy already runs migration:run; keep false unless you want double-run)
# DB_RUN_MIGRATIONS=false

# Browser origin(s) for CORS — use your staging site URL (e.g. http://staging.example.com)
# CORS_ORIGIN=http://staging.example.com

# Optional: demo tenant default for API calls without X-Tenant-Id (after seed:demo)
# DEV_TENANT_ID=a0000001-0000-4000-8000-000000000001

# Cookie secure flag — set to false when staging runs behind HTTP-only proxy
# COOKIE_SECURE=false
