{
  "name": "fesa",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @amateur/shared-types -w @amateur/shared-config && npm run build -w @amateur/api -w @amateur/web",
    "repo:guard": "node scripts/repo-guard.mjs",
    "i18n:check": "node scripts/check-i18n-parity.mjs",
    "lint": "eslint apps/api/src packages/*/src apps/web/src --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "seed:demo": "npm run seed:demo -w @amateur/api"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1"
  }
}
